# Local development defaults
KNOTODO_FRONTEND_PORT=4173
KNOTODO_BACKEND_PORT=8081
KNOTODO_LOG_LEVEL=INFO
KNOTODO_SERVE_BUILT_FRONTEND=0
KNOTODO_DISABLE_FRONTEND=0

# Optional storage overrides
# KNOTODO_DB_FILE=/absolute/path/to/state.json
# KNOTODO_LOCK_FILE=/absolute/path/to/state.json.lock
# KNOTODO_DB_BACKUP_FILE=/absolute/path/to/state.backup.json
# KNOTODO_LOCK_TIMEOUT=10

# Optional Docker build mirrors
# KNOTODO_APT_MIRROR_BASE=https://mirrors.tuna.tsinghua.edu.cn
# KNOTODO_NPM_REGISTRY=https://registry.npmmirror.com
# KNOTODO_PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
