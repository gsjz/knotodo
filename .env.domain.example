# Reverse-proxy deployment defaults
KNOTODO_FRONTEND_PORT=18082
KNOTODO_BACKEND_PORT=18083
KNOTODO_LOG_LEVEL=INFO
KNOTODO_SERVE_BUILT_FRONTEND=1
KNOTODO_DISABLE_FRONTEND=1

# Optional Docker build mirrors
# KNOTODO_APT_MIRROR_BASE=https://mirrors.tuna.tsinghua.edu.cn
# KNOTODO_NPM_REGISTRY=https://registry.npmmirror.com
# KNOTODO_PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
